9000 cls
9010 OPEN "I",#1,"DRIVE.DAT"
9020 INPUT #1,DRI$:INPUT #1,A$:INPUT #1,A$:INPUT #1,COLR$
9030 CLOSE #1
9040 v=11:gosub 9480:print "                                  SORTING NAMES"
9050 DIM A$(600),P(600)
9060 OPEN "I",#1,"NAME.DAT"
9070 IF EOF(1) THEN CLOSE #1:GOTO 9190
9080 AT=AT+1
9090 INPUT #1,A$(AT)
9180 GOTO 9070
9190 REM
9200 Z=0
9210 FOR I=1 TO AT: P(I)=I:NEXT I
9220 Z=AT
9230 GAP=Z
9240 GAP=INT(GAP/2)
9250 MAXIMUM=Z-GAP
9260 EX=0
9270 FOR I=1 TO MAXIMUM
9280 IPLUSG=I + GAP
9290 IF A$(P(I))>A$(P(IPLUSG)) THEN T=P(I):P(I)=P(IPLUSG):P(IPLUSG)=T:EX=EX+1
9300 NEXT I
9310 IF EX=0 THEN GOTO 9330
9320 GOTO 9250
9330 IF GAP<1 THEN GOTO 9350
9340 GOTO 9240
9350 OPEN "O",#1,dri$+"TEMP.DAT"
9400 FOR I=1 TO AT
9440 PRINT #1,A$(P(I))
9450 NEXT I
9460 CLOSE #1
9470 kill dri$+"name.dat":name "temp.dat" as "name.dat"
9471 close #1:system
9480 IF COLR$="Y" THEN COLOR V,0
9490 RETURN
