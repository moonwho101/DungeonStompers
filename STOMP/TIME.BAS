15000 SAX$=MID$(TIME$,1,2):SAX=VAL(SAX$)
15010 IF SAX=12 THEN GOSUB 15080:RETURN
15020 IF SAX>12 OR SAX=0 THEN GOSUB 15040:RETURN
15030 FDT$=" "+SAX$+":"+MID$(TIME$,4,2)+" am":RETURN
15040 IF SAX=0 THEN FDT$=" 12:"+MID$(TIME$,4,2)+" am":RETURN
15050 SAX=SAX-12
15060 FDT$=STR$(SAX)+":"+MID$(TIME$,4,2)+" pm"
15070 RETURN
15080 FDT$=STR$(SAX)+":"+MID$(TIME$,4,2)+" pm":RETURN
