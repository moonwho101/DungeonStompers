10 RANDOMIZE TIMER
20 OPEN "I",#1,"DRIVE.DAT"
30 INPUT #1,DRI$:INPUT #1,A$:INPUT #1,A$:INPUT #1,COLR$
40 CLOSE #1
50 OPEN "I",#1,DRI$+"board.dat"
60 INPUT #1,L2
70 INPUT #1,L1
80 CLOSE #1
81 DIM PLY$(L2,L1)
90 KEY OFF
100 CLS
110 V=11:GOSUB 11000:CENTER$="Dungeon Stomper Creation Program":PLAC=2:GOSUB 230
120 V=10:GOSUB 11000:CENTER$="The dungeon is "+STR$(L1)+" X"+STR$(L2):PLAC=10:GOSUB 230
130 V=14:GOSUB 11000:PR$=A$:CENTER$="Please wait creating board":PLAC=12:GOSUB 230
140 GOSUB 300
141 GOSUB 520
150 V=12:GOSUB 11000:LOCATE 25,1:CENTER$="Please wait saving board":PLAC=14:GOSUB 230
160 OPEN DRI$+"BOARD.DAT" FOR OUTPUT AS #2
170  PRINT #2,L2
180 PRINT #2,L1
190 FOR R=1 TO L2:FOR C=1 TO L1: PRINT #2,PLY$(R,C):NEXT C:NEXT R
200 CLOSE #2
220 RESET:SYSTEM
230 REM CENTER TEXT
240 X=(INT(80-LEN(CENTER$))/2)
250 LOCATE PLAC,X:PRINT CENTER$
260 RETURN
270 REM store answer in reply
280 REPLY$=""
290 RETURN
300 REM CREATE BOARD
320 FOR R=1 TO L2
330    FOR C=1 TO L1
340 P=INT(RND*26)+1
350 IF P>0 AND P<5 THEN OB$="*"
360 IF P>5 AND P<=10 THEN OB$="."
370 IF P=11 THEN OB$="R"
380 IF P=12 THEN OB$="A"
390 IF P=13 THEN OB$="B"
400 IF P=14 THEN OB$="C"
410 IF P=15 THEN OB$="D"
420 IF P=16 THEN OB$="E"
430 IF P=17 THEN OB$="F"
440 IF P=18 THEN OB$="G"
450 IF P=19 THEN OB$="H"
460 IF P=20 THEN OB$="I"
470 IF P=21 THEN OB$="J"
471 IF P=22 THEN OB$="K"
472 IF P=23 THEN GOSUB 9000
473 IF P=24 THEN GOSUB 9005
474 IF P=25 THEN OB$="N"
475 IF P=26 THEN OB$="O"
476 IF OB$="" THEN OB$="."
480     PLY$(R,C)=OB$
490    NEXT C
500 NEXT R
510 RETURN
520 OPEN "I",#1,DRI$+"LOCATION.DAT"
521 IF EOF(1) THEN RETURN
530 INPUT #1,A$
540 INPUT #1,B
550 INPUT #1,C
560 INPUT #1,D
570 INPUT #1,E$
580 INPUT #1,F$
590 INPUT #1,G$
600 INPUT #1,H$
900 PLY$(C,B)="Z"
901 IF E$="I" THEN PLY$(C,B)="."
1000 GOTO 521
9000  R4=INT(RND*3)+1
9001 IF R4=1 THEN OB$="L":RETURN
9002 OB$=".":RETURN
9005 R4=INT(RND*3)+1
9006 IF R4=1 THEN OB$="M":RETURN
9007 OB$=".":RETURN
11000 IF COLR$="Y" THEN COLOR V,0
11002 RETURN

