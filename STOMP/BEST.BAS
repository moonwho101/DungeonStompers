9000 FORMAT$="          \                                     \       #######"
9010 OPEN "I",#1,"DRIVE.DAT"
9020 INPUT #1,DRI$:INPUT #1,A$:INPUT #1,A$:INPUT #1,COLR$
9030 CLOSE #1
9040 V=11:GOSUB 9480:PRINT:PRINT "Please wait, ranking players..."
9050 DIM A$(400),B$(400),C$(400),D$(400),E$(400),F$(400),G$(400),H$(400),I(400),P(400)
9060 OPEN "I",#1,"LOCATION.DAT"
9070 IF EOF(1) THEN CLOSE #1:GOTO 9190
9080 AT=AT+1
9090 INPUT #1,A$(AT)
9100 INPUT #1,B$(AT)
9110 INPUT #1,C$(AT)
9120 INPUT #1,D$(AT)
9130 INPUT #1,E$(AT)
9140 INPUT #1,F$(AT)
9150 INPUT #1,G$(AT)
9160 INPUT #1,H$(AT)
9170 I(AT)=VAL(D$(AT))+VAL(F$(AT))
9180 GOTO 9070
9190 REM
9200 Z=0
9210 FOR I=1 TO AT: P(I)=I:NEXT I
9220 Z=AT
9230 GAP=Z
9240 GAP=INT(GAP/2)
9250 MAXIMUM=Z-GAP
9260 EX=0
9270 FOR I=1 TO MAXIMUM
9280 IPLUSG=I + GAP
9290 IF I(P(I))<I(P(IPLUSG)) THEN T=P(I):P(I)=P(IPLUSG):P(IPLUSG)=T:EX=EX+1
9300 NEXT I
9310 IF EX=0 THEN GOTO 9330
9320 GOTO 9250
9330 IF GAP<1 THEN GOTO 9350
9340 GOTO 9240
9350 CLS:OPEN "O",#1,"SCORE.DAT"
9360 PRINT #1,"                  DUNGEON STOMPER BEST PLAYER LIST ("+DATE$+")":PRINT #1,""
9370 Z=0
9380 PRINT #1,"          CHARACTER                                     STATUS/ARMOUR"
9390 PRINT #1,"                                                           RATING":PRINT #1,""
9400 FOR I=1 TO AT
9410 IF INSTR(A$(P(I)),"(mons") THEN GOTO 9450
9420 IF Z=0 THEN A$(P(I))=A$(P(I))+"  (Star Stomper!!)":Z=1
9430 'PRINT USING FORMAT$;A$(P(I));I(P(I))
9440 PRINT #1,USING FORMAT$;A$(P(I));I(P(I))
9450 NEXT I
9460 CLOSE #1
9470 SYSTEM
9480 IF COLR$="Y" THEN COLOR V,0
9490 RETURN
