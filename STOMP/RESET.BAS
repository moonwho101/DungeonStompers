1 ON ERROR GOTO 20
2 SCREEN 0:CLS
3 PRINT"RESETTING DUNGEON STOMPERS..."
4 OPEN "I",#1,"DRIVE.DAT"
5 INPUT #1,DRI$
6 CLOSE #1
7 OPEN "O",#1,DRI$+"NAME.DAT":CLOSE #1
8 OPEN "O",#1,DRI$+"LOCATION.DAT":CLOSE #1
9 OPEN "O",#1,DRI$+"CHRTR.DAT":CLOSE #1
10 OPEN "O",#1,DRI$+"MESSAGE.DAT":CLOSE #1
11 OPEN "O",#1,DRI$+"PLAY.DAT":CLOSE #1
12 OPEN "O",#1,DRI$+"DEAD.DAT":CLOSE #1
13 OPEN "O",#1,DRI$+"BOARD.DAT":CLOSE #1
14 OPEN "O",#1,DRI$+"SCORE.DAT":CLOSE #1:OPEN "O",#1,DRI$+"HANG.DAT"
15 CLOSE #1
16 OPEN "O",#1,DRI$+"DATE.DAT":PRINT #1,DATE$:CLOSE #1
17 OPEN "O",#1,DRI$+"PLAYER.DAT":CLOSE #1
18 KILL DRI$+"TEMP.DAT"
19 SYSTEM
20 SYSTEM
