10 SCREEN 0:CLS:DIM BRANDNEW$(100)
20 COLOR 15,0
21 PRINT "      DETERMINING MODEM REGISTER"
180 PRINT:PRINT "      Please enter COM port (ie  COM1:): ":XPOS=41:YPOS=3:LONG=7:LA=1:GOSUB 280
261 A$="1":PRINT:PRINT "      If this MONITORING system doesn't work, edit MDM.DEF to read 0":print "      and use WATCHDOG"
271 GOTO 9000
280 REM ENTERING JUST NUMBERS OR NUMBERS AND LETTERS
290     V=15:LENGTH=0
300     DOWN=0
310     LOCATE YPOS,XPOS+1:PRINT "_"
320     CURS=XPOS+1
330     A$=INKEY$
340     IF A$="" THEN 330
350     IF A$=CHR$(27) THEN RESET:RUN
360     IF LA=1 AND LENGTH=0 AND PART=0 AND ASC(A$)=13 THEN GOTO 330
370     IF ALL=1 AND LENGTH<LONG THEN GOTO 400
380     IF PART=0 AND ASC(A$)=13 AND LENGTH>=1 THEN LOCATE YPOS,XPOS+1:PRINT " ":GOSUB 640:RETURN
390     IF PART=1 AND ASC(A$)=13  THEN LOCATE YPOS,XPOS+1:PRINT " ":GOSUB 640:RETURN
400     IF ASC(A$)=8 THEN GOSUB 540:GOTO 330
410     IF LENGTH>=LONG THEN 330
420     IF LA=1 THEN GOTO 450
430     IF NUM=1 AND ASC(A$)=32 THEN GOTO 450
440     IF NUM=0 AND ASC(A$)<48 OR ASC(A$)>57  THEN GOTO 330
450     XPOS=XPOS+1
460     LOCATE YPOS,XPOS:PRINT A$;"_"
470     LENGTH=LENGTH+1
480     IF LENGTH>=LONG THEN LENGTH=LONG
490 IF A$<="z" AND A$>="a" THEN A$=CHR$((ASC(A$)-32))
500     BRANDNEW$(LENGTH)=A$
510 GOTO 330
520 '
530 '
540 REM CURSOR BACK ON ENTRY ROUTINES
550     LENGTH=LENGTH-1
560     IF LENGTH<0 THEN LENGTH=0
570     IF XPOS<=CURS THEN XPOS=CURS
580     LOCATE YPOS,XPOS:PRINT "_ "
590     XPOS=XPOS-1
600     LOCATE YPOS,XPOS
610     RETURN
620 '
630 '
640 REM STORE ENTRY INTO STRING CALLED REPLY$
650     REPLY$=""
660     FOR REPLY=1 TO LENGTH
670         REPLY$=REPLY$+BRANDNEW$(REPLY)
680     NEXT REPLY
690     RETURN
700 '
710 '
9000 PRINT :PRINT "      Determining MODEM STATUS REGISTER"
9001  OPEN REPLY$+"300,N,8,1,LF" AS #1
9002  FOR I=1 TO 5:A=INP(&H3FE):NEXT I
9003  PRINT:PRINT:PRINT "      MODEM STATUS REGISTER IS";A
9004  PRINT "      THIS IS USED TO CHECK TO SEE IF USER HANGS UP IN STOMP."
9005 CLOSE #1
9006 OPEN "MDM.DEF" FOR OUTPUT AS #1:PRINT #1,A:CLOSE #1:OPEN "COM.DAT" FOR OUTPUT AS #1:PRINT #1,REPLY$:CLOSE #1
9007 PRINT:PRINT "      PRESS RETURN"
9008 S$=INKEY$:IF S$="" THEN GOTO 9008
9009 SYSTEM
19000 PRINT :PRINT "      Determining MODEM STATUS REGISTER"
19001  OPEN REPLY$+"300,N,8,1,LF" AS #1
19002  FOR I=1 TO 5:A=INP(&H2FE):NEXT I
19003  PRINT:PRINT:PRINT "      MODEM STATUS REGISTER IS";A
19004  PRINT "      THIS IS USED TO CHECK TO SEE IF USER HANGS UP IN STOMP."
19005 CLOSE #1
19006 OPEN "MDM.DEF" FOR OUTPUT AS #1:PRINT #1,A:CLOSE #1
19007 PRINT:PRINT "      PRESS RETURN"
19008 S$=INKEY$:IF S$="" THEN GOTO 19008
20000 SYSTEM
